import { NextRequest, NextResponse } from 'next/server';
import jsPDF from 'jspdf';
import { robotoregularBase64 } from '@/fonts/roboto-regular';
import { robotoboldBase64 } from '@/fonts/roboto-bold';

interface InvoiceItem {
  name: string;
  nameBg?: string;
  quantity: number;
  price: number;
}

interface CurrencySettings {
  showBGNReference: boolean;
  bgnToEurRate: number;
}

const DEFAULT_SELLER = {
  name: 'TekHub BG EOOD',
  eik: '123456789',
  vatNumber: 'BG123456789',
  mol: 'Ivan Ivanov',
  address: 'bul. Vitosha 100',
  city: 'Sofia 1000',
  phone: '+359 2 123 4567',
  email: 'info@techhub.bg',
  bank: 'Unicredit Bulbank',
  iban: 'BG80UNCR96601234567890',
  bic: 'UNCRBGSF',
};

// Fetch currency settings from Strapi
async function getCurrencySettings(): Promise<CurrencySettings> {
  try {
    const response = await fetch(
      `${process.env.NEXT_PUBLIC_STRAPI_URL}/api/global-setting`,
      { cache: 'no-store' }
    );

    if (!response.ok) {
      console.warn('Failed to fetch currency settings, using defaults');
      return { showBGNReference: true, bgnToEurRate: 1.95583 };
    }

    const result = await response.json();
    return {
      showBGNReference: result.data?.showBGNReference ?? true,
      bgnToEurRate: parseFloat(result.data?.bgnToEurRate) || 1.95583,
    };
  } catch (error) {
    console.error('Error fetching currency settings:', error);
    return { showBGNReference: true, bgnToEurRate: 1.95583 };
  }
}

// Format price with EUR primary and optional BGN secondary
function formatPrice(eurPrice: number, settings: CurrencySettings): {
  eur: string;
  bgn: string;
  primary: string;
  secondary: string;
} {
  const bgnPrice = eurPrice * settings.bgnToEurRate;
  return {
    eur: eurPrice.toFixed(2),
    bgn: bgnPrice.toFixed(2),
    primary: `€${eurPrice.toFixed(2)}`,
    secondary: `${bgnPrice.toFixed(2)} лв`,
  };
}

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    console.log('📄 Invoice generation request:', { invoiceNumber: body.invoiceNumber });

    const {
      invoiceNumber,
      issuedDate,
      buyer,
      items,
      subtotal,
      vatAmount,
      total,
      paymentMethod,
      orderNumber,
      promoCode,
      promoDiscount,
    } = body;

    if (!invoiceNumber || !buyer || !items || items.length === 0) {
      console.error('❌ Missing required fields');
      return NextResponse.json(
        { error: 'Missing required fields' },
        { status: 400 }
      );
    }

    // Fetch currency settings
    const settings = await getCurrencySettings();
    console.log('💱 Currency settings:', settings);

    const calculatedSubtotal = subtotal || items.reduce((sum: number, item: any) => sum + item.price * item.quantity, 0);
    const calculatedVat = vatAmount || (calculatedSubtotal * 0.2);
    const calculatedTotal = total || (calculatedSubtotal * 1.2);

    console.log('✅ Generating PDF with jsPDF and Cyrillic support...');

    const doc = new jsPDF();

    // Add custom font with Cyrillic support
    try {
      doc.addFileToVFS('Roboto-Regular.ttf', robotoregularBase64);
      doc.addFont('Roboto-Regular.ttf', 'Roboto', 'normal');
      doc.addFileToVFS('Roboto-Bold.ttf', robotoboldBase64);
      doc.addFont('Roboto-Bold.ttf', 'Roboto', 'bold');
      doc.setFont('Roboto');
      console.log('✅ Cyrillic font loaded');
    } catch (fontError) {
      console.error('⚠️ Font loading failed, using default:', fontError);
    }

    const pageWidth = doc.internal.pageSize.getWidth();
    const pageHeight = doc.internal.pageSize.getHeight();
    const leftMargin = 15;
    const rightMargin = pageWidth - 15;
    let yPos = 20;

    // HEADER - Left Side
    doc.setFontSize(24);
    doc.setFont('Roboto', 'bold');
    doc.text('TechHub.bg', leftMargin, yPos);

    yPos += 8;
    doc.setFontSize(10);
    doc.setFont('Roboto', 'normal');
    doc.text('Computer Hardware & Peripherals', leftMargin, yPos);

    // HEADER - Right Side (Bilingual)
    let rightYPos = 20;
    doc.setFontSize(20);
    doc.setFont('Roboto', 'bold');
    doc.setTextColor(0, 181, 83); // Green color
    doc.text('ФАКТУРА / INVOICE', rightMargin, rightYPos, { align: 'right' });

    rightYPos += 8;
    doc.setTextColor(0, 0, 0); // Back to black
    doc.setFontSize(12);
    doc.setFont('Roboto', 'normal');
    doc.text(`№ ${invoiceNumber}`, rightMargin, rightYPos, { align: 'right' });

    rightYPos += 7;
    const formattedDate = new Date(issuedDate || new Date()).toLocaleDateString('bg-BG');
    doc.setFontSize(10);
    doc.text(`Дата / Date: ${formattedDate}`, rightMargin, rightYPos, { align: 'right' });

    if (orderNumber) {
      rightYPos += 6;
      doc.setTextColor(100, 100, 100);
      doc.text(`Поръчка / Order: ${orderNumber}`, rightMargin, rightYPos, { align: 'right' });
      doc.setTextColor(0, 0, 0);
    }

    // Line separator
    yPos = 50;
    doc.setDrawColor(200, 200, 200);
    doc.line(leftMargin, yPos, rightMargin, yPos);

    // SELLER INFO - Left Column (Bilingual)
    yPos = 60;
    doc.setFontSize(10);
    doc.setFont('Roboto', 'bold');
    doc.text('ДОСТАВЧИК / SELLER:', leftMargin, yPos);

    yPos += 6;
    doc.setFont('Roboto', 'normal');
    doc.text(DEFAULT_SELLER.name, leftMargin, yPos);

    yPos += 5;
    doc.text(`ЕИК / EIN: ${DEFAULT_SELLER.eik}`, leftMargin, yPos);

    yPos += 5;
    doc.text(`ДДС / VAT: ${DEFAULT_SELLER.vatNumber}`, leftMargin, yPos);

    yPos += 5;
    doc.text(`МОЛ / Director: ${DEFAULT_SELLER.mol}`, leftMargin, yPos);

    yPos += 5;
    doc.text(DEFAULT_SELLER.address, leftMargin, yPos);

    yPos += 5;
    doc.text(DEFAULT_SELLER.city, leftMargin, yPos);

    // BUYER INFO - Right Column (Bilingual)
    let buyerY = 60;
    const buyerX = 105;
    doc.setFont('Roboto', 'bold');
    doc.text('ПОЛУЧАТЕЛ / BUYER:', buyerX, buyerY);

    buyerY += 6;
    doc.setFont('Roboto', 'normal');
    doc.text(buyer.name || buyer.companyName, buyerX, buyerY);

    if (buyer.eik) {
      buyerY += 5;
      doc.text(`ЕИК / EIN: ${buyer.eik}`, buyerX, buyerY);
    }

    if (buyer.vatNumber) {
      buyerY += 5;
      doc.text(`ДДС / VAT: ${buyer.vatNumber}`, buyerX, buyerY);
    }

    if (buyer.mol) {
      buyerY += 5;
      doc.text(`МОЛ / Director: ${buyer.mol}`, buyerX, buyerY);
    }

    buyerY += 5;
    // Wrap address if too long
    const addressLines = doc.splitTextToSize(buyer.address, 85);
    addressLines.forEach((line: string) => {
      doc.text(line, buyerX, buyerY);
      buyerY += 5;
    });

    if (buyer.city) {
      doc.text(buyer.city, buyerX, buyerY);
      buyerY += 5;
    }

    // ITEMS TABLE (Bilingual Headers)
    yPos = Math.max(yPos, buyerY) + 10;

    // Table header
    doc.setFillColor(245, 245, 245);
    doc.rect(leftMargin, yPos - 4, rightMargin - leftMargin, 7, 'F');

    doc.setFontSize(9);
    doc.setFont('Roboto', 'bold');
    doc.text('№', leftMargin + 2, yPos);
    doc.text('Описание / Description', leftMargin + 15, yPos);
    doc.text('Кол. / Qty', leftMargin + 110, yPos, { align: 'center' });
    doc.text('Цена / Price', leftMargin + 140, yPos, { align: 'right' });
    doc.text('Общо / Total', rightMargin - 5, yPos, { align: 'right' });

    yPos += 7;
    doc.setFont('Roboto', 'normal');
    doc.setFontSize(8);

    // Items rows
    items.forEach((item: InvoiceItem, index: number) => {
      // Check if we need a new page
      if (yPos > pageHeight - 80) {
        doc.addPage();
        yPos = 20;
      }

      if (index % 2 === 0) {
        doc.setFillColor(250, 250, 250);
        doc.rect(leftMargin, yPos - 4, rightMargin - leftMargin, 6, 'F');
      }

      // Use Bulgarian name if available, otherwise English
      const itemName = (item.nameBg || item.name);
      const truncatedName = itemName.length > 50 ? itemName.substring(0, 47) + '...' : itemName;
      const itemTotal = item.price * item.quantity;

      // Format prices with EUR primary
      const itemPrice = formatPrice(item.price, settings);
      const itemTotalPrice = formatPrice(itemTotal, settings);

      doc.text((index + 1).toString(), leftMargin + 2, yPos);
      doc.text(truncatedName, leftMargin + 15, yPos);
      doc.text(item.quantity.toString(), leftMargin + 110, yPos, { align: 'center' });
      doc.text(itemPrice.primary, leftMargin + 140, yPos, { align: 'right' });
      doc.text(itemTotalPrice.primary, rightMargin - 5, yPos, { align: 'right' });

      yPos += 6;
    });

    // Line after items
    yPos += 2;
    doc.setDrawColor(200, 200, 200);
    doc.line(leftMargin, yPos, rightMargin, yPos);

    // TOTALS (EUR Primary, BGN Secondary if enabled)
    yPos += 8;
    const labelX = rightMargin - 95;
    const valueX = rightMargin - 5;

    doc.setFontSize(10);
    doc.setFont('Roboto', 'normal');

    // Tax Base
    const subtotalFormatted = formatPrice(calculatedSubtotal, settings);
    doc.text('Данъчна основа / Tax Base:', labelX, yPos);
    doc.text(subtotalFormatted.primary, valueX, yPos, { align: 'right' });
    
    if (settings.showBGNReference) {
      yPos += 4;
      doc.setFontSize(8);
      doc.setTextColor(100, 100, 100);
      doc.text(`(${subtotalFormatted.secondary})`, valueX, yPos, { align: 'right' });
      doc.setTextColor(0, 0, 0);
      yPos += 2;
    }
    
    yPos += 6;

    // PROMO DISCOUNT (if applicable)
    if (promoCode && promoDiscount && promoDiscount > 0) {
      const promoFormatted = formatPrice(promoDiscount, settings);
      doc.setTextColor(0, 181, 83); // Green for discount
      doc.text(`Промо код / Promo (${promoCode}):`, labelX, yPos);
      doc.text(`-${promoFormatted.primary}`, valueX, yPos, { align: 'right' });
      
      if (settings.showBGNReference) {
        yPos += 4;
        doc.setFontSize(8);
        doc.setTextColor(100, 100, 100);
        doc.text(`(-${promoFormatted.secondary})`, valueX, yPos, { align: 'right' });
        yPos += 2;
      }
      
      doc.setTextColor(0, 0, 0); // Back to black
      doc.setFontSize(10);
      yPos += 6;
    }

    // VAT
    const vatFormatted = formatPrice(calculatedVat, settings);
    doc.text('ДДС 20% / VAT 20%:', labelX, yPos);
    doc.text(vatFormatted.primary, valueX, yPos, { align: 'right' });
    
    if (settings.showBGNReference) {
      yPos += 4;
      doc.setFontSize(8);
      doc.setTextColor(100, 100, 100);
      doc.text(`(${vatFormatted.secondary})`, valueX, yPos, { align: 'right' });
      doc.setTextColor(0, 0, 0);
      yPos += 2;
    }

    yPos += 2;
    doc.setDrawColor(0, 0, 0);
    doc.line(labelX, yPos, rightMargin, yPos);

    // TOTAL
    yPos += 6;
    const totalFormatted = formatPrice(calculatedTotal, settings);
    doc.setFont('Roboto', 'bold');
    doc.setFontSize(12);
    doc.text('ОБЩО / TOTAL:', labelX, yPos);
    doc.setTextColor(0, 181, 83); // Green
    doc.text(totalFormatted.primary, valueX, yPos, { align: 'right' });
    
    if (settings.showBGNReference) {
      yPos += 5;
      doc.setFontSize(10);
      doc.setTextColor(100, 100, 100);
      doc.text(`(${totalFormatted.secondary})`, valueX, yPos, { align: 'right' });
    }
    
    doc.setTextColor(0, 0, 0); // Back to black
    doc.setFontSize(10);

    // PAYMENT METHOD (Bilingual)
    yPos += 15;
    doc.setFont('Roboto', 'bold');
    doc.text('МЕТОД НА ПЛАЩАНЕ / PAYMENT METHOD:', leftMargin, yPos);

    const paymentLabels: Record<string, { bg: string; en: string }> = {
      cod: { bg: 'Наложен платеж', en: 'Cash on Delivery' },
      card: { bg: 'Кредитна/Дебитна карта', en: 'Credit/Debit Card' },
      bank: { bg: 'Банков превод', en: 'Bank Transfer' },
    };

    yPos += 6;
    doc.setFont('Roboto', 'normal');
    const payment = paymentLabels[paymentMethod] || { bg: paymentMethod, en: paymentMethod };
    doc.text(`${payment.bg} / ${payment.en}`, leftMargin, yPos);

    if (paymentMethod === 'bank') {
      yPos += 10;
      doc.setFont('Roboto', 'bold');
      doc.text('БАНКОВИ ДЕТАЙЛИ / BANK DETAILS:', leftMargin, yPos);

      yPos += 6;
      doc.setFont('Roboto', 'normal');
      doc.text(`Банка / Bank: ${DEFAULT_SELLER.bank}`, leftMargin, yPos);

      yPos += 5;
      doc.text(`IBAN: ${DEFAULT_SELLER.iban}`, leftMargin, yPos);

      yPos += 5;
      doc.text(`BIC: ${DEFAULT_SELLER.bic}`, leftMargin, yPos);
    }

    // FOOTER - Fixed position at bottom
    const footerY = pageHeight - 35;

    doc.setFontSize(9);
    doc.setFont('Roboto', 'normal');

    // Left signature
    doc.text('Издал / Prepared by:', leftMargin, footerY);
    doc.line(leftMargin + 35, footerY + 8, leftMargin + 70, footerY + 8);
    doc.setFontSize(7);
    doc.text('(подпис / signature)', leftMargin + 37, footerY + 12);

    // Right signature
    doc.setFontSize(9);
    const rightSigX = 115;
    doc.text('Получил / Received by:', rightSigX, footerY);
    doc.line(rightSigX + 35, footerY + 8, rightSigX + 70, footerY + 8);
    doc.setFontSize(7);
    doc.text('(подпис / signature)', rightSigX + 37, footerY + 12);

    // Footer text (Bilingual)
    doc.setFontSize(7);
    doc.setTextColor(100, 100, 100);
    doc.text(
      'Тази фактура е издадена електронно и е валидна без подпис.',
      pageWidth / 2,
      footerY + 18,
      { align: 'center' }
    );
    doc.text(
      'This invoice is issued electronically and is valid without signature.',
      pageWidth / 2,
      footerY + 21,
      { align: 'center' }
    );
    doc.text(
      `TechHub.bg | ${DEFAULT_SELLER.email} | ${DEFAULT_SELLER.phone}`,
      pageWidth / 2,
      footerY + 25,
      { align: 'center' }
    );

    // Generate PDF
    const pdfBuffer = Buffer.from(doc.output('arraybuffer'));
    console.log('✅ PDF generated successfully with EUR primary, size:', pdfBuffer.length, 'bytes');

    return new NextResponse(pdfBuffer, {
      status: 200,
      headers: {
        'Content-Type': 'application/pdf',
        'Content-Disposition': `attachment; filename="faktura-${invoiceNumber}.pdf"`,
        'Content-Length': pdfBuffer.length.toString(),
      },
    });
  } catch (error: any) {
    console.error('❌ Invoice generation error:', error);
    console.error('Error stack:', error.stack);
    return NextResponse.json(
      { error: 'Failed to generate invoice', details: error.message },
      { status: 500 }
    );
  }
}
